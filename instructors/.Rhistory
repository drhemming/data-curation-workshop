library(tidyverse)
library(lubridate)
library(stringr)
#-----------------------------
# 1. READ DATA
#-----------------------------
df <- read_csv("/Users/khem480/Documents/Projects/data-curation-workshop/data/plants_site_A_cleaned.csv", show_col_types = FALSE)
#-----------------------------
# 1. READ DATA
#-----------------------------
df <- read_csv("Users/khem480/Documents/Projects/data-curation-workshop/data/plants_site_A_cleaned.csv", show_col_types = FALSE)
#-----------------------------
# 1. READ DATA
#-----------------------------
df <- read_csv("//Users/khem480/Documents/Projects/data-curation-workshop/data/plants_site_A_cleaned.csv", show_col_types = FALSE)
#-----------------------------
# 1. READ DATA
#-----------------------------
df <- read_csv("//Users/khem480/Documents/Projects/data-curation-workshop/data/plants_site_A.csv", show_col_types = FALSE)
#-----------------------------
# 2. STANDARDISE Date_Planted
#-----------------------------
df <- df %>%
mutate(
Corrected_Date_planted = case_when(
# Empty stays empty
is.na(Date_Planted) | Date_Planted == "" ~ NA_character_,
# Already full date (with year)
str_detect(Date_Planted, "\\d{1,2}/\\d{1,2}/\\d{2,4}") ~
format(dmy(Date_Planted), "%d/%m/%Y"),
# US format (mm/dd/yy)
str_detect(Date_Planted, "^\\d{1,2}/\\d{1,2}/\\d{2}$") &
mdy(Date_Planted, quiet = TRUE) %>% !is.na() ~
format(mdy(Date_Planted), "%d/%m/%Y"),
# Anything without year (e.g. "20-Sep", "22-Jun")
TRUE ~ NA_character_
)
)
#-----------------------------
# 3. CLEAN CATEGORICAL COLUMNS
#-----------------------------
df <- df %>%
mutate(
# SITE
cleaned_Site = str_to_title(Site),
cleaned_Site = str_replace_all(cleaned_Site, "Site_A|Site_A", "Site_A"),
# LOCATION
cleaned_Location = case_when(
str_detect(tolower(Location), "loc_1|loc_l") ~ "Loc_1",
str_detect(tolower(Location), "loc_2") ~ "Loc_2",
TRUE ~ NA_character_
),
# QUADRAT
cleaned_Quadrat = str_to_upper(Quadrat),
cleaned_Quadrat = str_replace(cleaned_Quadrat, "^Q(\\d+)$", "Q\\1"),
# SPECIES
cleaned_Species = str_trim(Species),
cleaned_Species = case_when(
str_detect(cleaned_Species, "Leptospermun") ~ "Leptospermum scoparium",
str_detect(cleaned_Species, "Phormiun") ~ "Phormium tenax",
cleaned_Species == "Coprosma robust" ~ "Coprosma robusta",
cleaned_Species == "Hebe species" ~ NA_character_,
TRUE ~ cleaned_Species
)
)
head(df)
glimpse(df)
names(df$cleaned_Site)
unique(df$cleaned_Site)
unique(df$cleaned_Location)
unique(df$cleaned_Species)
#-----------------------------
# 4. FIX FLOWERING COLUMN
#-----------------------------
df <- df %>%
mutate(
cleaned_Flowering = case_when(
Flowering %in% c("Y", "YES", "Yes", "yes") ~ "Yes",
Flowering %in% c("N", "NO", "No", "no", "0") ~ "No",
TRUE ~ NA_character_
)
)
# quick summary stats
df %>%
summarise(
mean_age = mean(Age_Months, na.rm = TRUE),
min_age = min(Age_Months, na.rm = TRUE),
max_age = max(Age_Months, na.rm = TRUE)
)
#-----------------------------
# 6. PARSE MEASUREMENT DATE
#-----------------------------
df <- df %>%
mutate(
parsed_Date_measured = parse_date_time(
Date_Measured,
orders = c("dmy", "dmY", "mdy", "d-b-y", "d-b-Y"),
quiet = TRUE
)
)
#-----------------------------
# 7. CALCULATE AGE (MONTHS)
#-----------------------------
df <- df %>%
mutate(
parsed_Date_planted = dmy(Corrected_Date_planted),
Age_Months = case_when(
is.na(parsed_Date_planted) ~ NA_real_,
is.na(parsed_Date_measured) ~ NA_real_,
TRUE ~ interval(parsed_Date_planted, parsed_Date_measured) %/% months(1)
)
)
#-----------------------------
# 2. STANDARDISE Date_Planted
#-----------------------------
df <- df %>%
mutate(
Corrected_Date_planted = case_when(
# Empty stays empty
is.na(Date_Planted) | Date_Planted == "" ~ NA_character_,
# Already full date (with year)
str_detect(Date_Planted, "\\d{1,2}/\\d{1,2}/\\d{2,4}") ~
format(dmy(Date_Planted), "%d/%m/%Y"),
# US format (mm/dd/yy)
str_detect(Date_Planted, "^\\d{1,2}/\\d{1,2}/\\d{2}$") &
mdy(Date_Planted, quiet = TRUE) %>% !is.na() ~
format(mdy(Date_Planted), "%d/%m/%Y"),
# Anything without year (e.g. "20-Sep", "22-Jun")
TRUE ~ NA_character_
)
)
#-----------------------------
# 3. CLEAN CATEGORICAL COLUMNS
#-----------------------------
df <- df %>%
mutate(
# SITE
cleaned_Site = str_to_title(Site),
cleaned_Site = str_replace_all(cleaned_Site, "Site_A|Site_A", "Site_A"),
# LOCATION
cleaned_Location = case_when(
str_detect(tolower(Location), "loc_1|loc_l") ~ "Loc_1",
str_detect(tolower(Location), "loc_2") ~ "Loc_2",
TRUE ~ NA_character_
),
# QUADRAT
cleaned_Quadrat = str_to_upper(Quadrat),
cleaned_Quadrat = str_replace(cleaned_Quadrat, "^Q(\\d+)$", "Q\\1"),
# SPECIES
cleaned_Species = str_trim(Species),
cleaned_Species = case_when(
str_detect(cleaned_Species, "Leptospermun") ~ "Leptospermum scoparium",
str_detect(cleaned_Species, "Phormiun") ~ "Phormium tenax",
cleaned_Species == "Coprosma robust" ~ "Coprosma robusta",
cleaned_Species == "Hebe species" ~ NA_character_,
TRUE ~ cleaned_Species
)
)
#-----------------------------
# 4. FIX FLOWERING COLUMN
#-----------------------------
df <- df %>%
mutate(
cleaned_Flowering = case_when(
Flowering %in% c("Y", "YES", "Yes", "yes") ~ "Yes",
Flowering %in% c("N", "NO", "No", "no", "0") ~ "No",
TRUE ~ NA_character_
)
)
#-----------------------------
# 5. ADD COMMON NAMES
#-----------------------------
df <- df %>%
mutate(
Common_Name = case_when(
cleaned_Species == "Leptospermum scoparium" ~ "Mānuka",
cleaned_Species == "Phormium tenax" ~ "Harakeke",
cleaned_Species == "Pittosporum tenuifolium" ~ "Kōhūhū",
cleaned_Species == "Coprosma robusta" ~ "Karamū",
cleaned_Species == "Pseudopanax crassifolius" ~ "Lancewood",
cleaned_Species == "Hebe speciosa" ~ "Hebe",
TRUE ~ NA_character_
)
)
#-----------------------------
# 6. PARSE MEASUREMENT DATE
#-----------------------------
df <- df %>%
mutate(
parsed_Date_measured = parse_date_time(
Date_Measured,
orders = c("dmy", "dmY", "mdy", "d-b-y", "d-b-Y"),
quiet = TRUE
)
)
#-----------------------------
# 7. CALCULATE AGE (MONTHS)
#-----------------------------
df <- df %>%
mutate(
parsed_Date_planted = dmy(Corrected_Date_planted),
Age_Months = case_when(
is.na(parsed_Date_planted) ~ NA_real_,
is.na(parsed_Date_measured) ~ NA_real_,
TRUE ~ interval(parsed_Date_planted, parsed_Date_measured) %/% months(1)
)
)
#-----------------------------
# 8. FLAG LOGICAL ISSUES (OPTIONAL BUT USEFUL)
#-----------------------------
df <- df %>%
mutate(
flag_issue = case_when(
Percentage_Cover < 0 ~ "Invalid cover",
Num_Flowers < 0 ~ "Invalid flowers",
cleaned_Flowering == "No" & Num_Flowers > 0 ~ "Flower mismatch",
cleaned_Flowering == "Yes" & Num_Flowers == 0 ~ "Flower mismatch",
TRUE ~ NA_character_
)
)
#-----------------------------
# 9. OUTPUT CLEAN DATA
#-----------------------------
write_csv(df, "plants_site_A_cleaned_final.csv")
# quick summary stats
df %>%
summarise(
mean_age = mean(Age_Months, na.rm = TRUE),
min_age = min(Age_Months, na.rm = TRUE),
max_age = max(Age_Months, na.rm = TRUE)
)
